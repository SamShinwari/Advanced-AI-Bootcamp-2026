      },
      "source": [
        "from nltk.tokenize import word_tokenize\n",
        "\n",
        "def pos_tag_text(text):\n",
        "\n",
        "    tokens = word_tokenize(str(text))\n",
        "\n",
        "    return nltk.pos_tag(tokens)\n",
        "\n",
        "df[\"pos_tags\"] = df[\"description\"].apply(pos_tag_text)\n",
        "\n",
        "df.head()"
      ],
