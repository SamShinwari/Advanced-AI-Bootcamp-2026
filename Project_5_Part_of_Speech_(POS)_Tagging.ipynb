        "('not', 'RB'),\n",
        "('forgive', 'VB'),\n",
        "('or', 'CC'),\n",
        "('forget', 'VB'),\n",
        "('those', 'DT'),\n",
        "('who', 'WP'),\n",
        "('murder', 'VBP'),\n",
        "('its', 'PRP$'),\n",
