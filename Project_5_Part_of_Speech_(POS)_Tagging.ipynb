      "cell_type": "markdown",
      "metadata": {
        "id": "08b8f257"
      },
      "source": [
        "# Step 7: POS Tag Meaning\n",
        "\n",
        "Create a dictionary for better understanding."
      ]
    },
    {
      "cell_type": "code",
      "metadata": {
        "id": "7317f94d",
        "outputId": "2c9485bb-1006-41a3-f135-2cf718488f4c",
        "colab": {
          "base_uri": "https://localhost:8080/"
        }
      },
      "source": [
        "tag_meaning = {\n",
        "    \"NN\": \"Noun\",\n",
        "    \"NNS\": \"Plural Noun\",\n",
        "    \"NNP\": \"Proper Noun\",\n",
        "    \"NNPS\": \"Proper Noun Plural\",\n",
        "\n",
        "    \"VB\": \"Verb\",\n",
        "    \"VBD\": \"Verb Past\",\n",
        "    \"VBG\": \"Verb Gerund\",\n",
        "    \"VBN\": \"Verb Past Participle\",\n",
        "    \"VBP\": \"Verb Present\",\n",
        "    \"VBZ\": \"Verb Present (3rd Person)\",\n",
        "\n",
        "    \"JJ\": \"Adjective\",\n",
        "    \"JJR\": \"Comparative Adjective\",\n",
        "    \"JJS\": \"Superlative Adjective\",\n",
        "\n",
        "    \"RB\": \"Adverb\",\n",
        "    \"RBR\": \"Comparative Adverb\",\n",
        "    \"RBS\": \"Superlative Adverb\",\n",
        "\n",
        "    \"DT\": \"Determiner\",\n",
        "    \"IN\": \"Preposition\",\n",
        "    \"CC\": \"Conjunction\",\n",
        "    \"PRP\": \"Pronoun\",\n",
        "    \"PRP$\": \"Possessive Pronoun\",\n",
        "    \"MD\": \"Modal\",\n",
        "    \"WP\": \"Wh-Pronoun\",\n",
        "    \".\": \"Punctuation\"\n",
        "}\n",
        "\n",
        "pos_df[\"Meaning\"] = pos_df[\"POS_Tag\"].map(tag_meaning)\n",
        "\n",
        "print(pos_df)"
      ],
      "execution_count": 65,
      "outputs": [
        {
          "output_type": "stream",
          "name": "stdout",
          "text": [
            "         Word POS_Tag                    Meaning\n",
            "0         The      DT                 Determiner\n",
            "1   Ukrainian      JJ                  Adjective\n",
            "2   president      NN                       Noun\n",
            "3        says     VBZ  Verb Present (3rd Person)\n",
            "4         the      DT                 Determiner\n",
            "5     country      NN                       Noun\n",
            "6        will      MD                      Modal\n",
            "7         not      RB                     Adverb\n",
            "8     forgive      VB                       Verb\n",
            "9          or      CC                Conjunction\n",
            "10     forget      VB                       Verb\n",
            "11      those      DT                 Determiner\n",
            "12        who      WP                 Wh-Pronoun\n",
            "13     murder     VBP               Verb Present\n",
            "14        its    PRP$         Possessive Pronoun\n",
            "15  civilians     NNS                Plural Noun\n",
            "16          .       .                Punctuation\n"
          ]
        }
      ]
    },
    {
      "cell_type": "markdown",
      "metadata": {
        "id": "da1a9156"
      },
      "source": [
        "---"
      ]
    },
